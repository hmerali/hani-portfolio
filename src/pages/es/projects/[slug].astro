---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CaseStudy from '../../../components/CaseStudy.astro';
import { getContent } from '../../../i18n/content';

const lang = 'es';
const t = getContent(lang);

export function getStaticPaths() {
  // Slugs are shared across locales; iterate the canonical (en) list.
  const all = getContent('en').projects;
  return all.map((project, index) => ({
    params: { slug: project.slug },
    props: { index },
  }));
}

const { index } = Astro.props;
const project = t.projects[index];
const prev = index > 0 ? t.projects[index - 1] : null;
const next = index < t.projects.length - 1 ? t.projects[index + 1] : null;
---

<BaseLayout
  title={project.title}
  description={project.summary}
  lang={lang}
  altHref={`/projects/${project.slug}`}
>
  <CaseStudy project={project} prev={prev} next={next} lang={lang} t={t} />
</BaseLayout>
