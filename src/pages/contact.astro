---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const description =
  'Get in touch with Hani Merali — email, LinkedIn, and GitHub.';

const methods = [
  {
    label: 'Email',
    value: site.email,
    href: site.links.email,
    note: 'Best for anything — I read everything.',
    icon: 'M3 5.5h18v13H3zM3 6l9 7 9-7',
    external: false,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/hmerali',
    href: site.links.linkedin,
    note: 'Connect and see my background.',
    icon: 'M4 4h4v16H4zM4 4v16m6 0V10m0 10h4v-7a3 3 0 016 0v7h-4',
    external: true,
  },
  {
    label: 'GitHub',
    value: 'github.com/hmerali',
    href: site.links.github,
    note: 'Code and projects.',
    icon: 'M9 19c-4 1.5-4-2-6-2.5m12 4.5v-3.5a3 3 0 00-.8-2.3c2.6-.3 5.3-1.3 5.3-5.8a4.5 4.5 0 00-1.3-3.2 4.2 4.2 0 00-.1-3.2s-1-.3-3.4 1.3a11.6 11.6 0 00-6 0C6 3.4 5 3.7 5 3.7a4.2 4.2 0 00-.1 3.2A4.5 4.5 0 003.5 10c0 4.5 2.7 5.5 5.3 5.8a3 3 0 00-.8 2.3V21',
    external: true,
  },
];
---

<BaseLayout title="Contact" description={description}>
  <section class="section contact">
    <div class="container contact__inner">
      <header data-reveal>
        <p class="eyebrow">Contact</p>
        <h1>Let’s talk.</h1>
        <p class="lead measure">
          Whether it’s civic technology, accessibility, data for good, or a role you
          think I’d be great for — I’d love to hear from you.
        </p>
      </header>

      <ul class="contact__methods">
        {
          methods.map((m, i) => (
            <li data-reveal style={`--reveal-delay:${i * 80}ms`}>
              <a
                href={m.href}
                class="contact__card"
                {...m.external ? { target: '_blank', rel: 'noopener' } : {}}
              >
                <span class="contact__icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d={m.icon} stroke="currentColor" stroke-width="1.6"
                      stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="contact__detail">
                  <span class="contact__label">{m.label}</span>
                  <span class="contact__value">{m.value}</span>
                  <span class="contact__note">{m.note}</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>

      <p class="contact__resume" data-reveal>
        Prefer the short version?
        <a href={site.links.resume} target="_blank" rel="noopener">Download my résumé (PDF)</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact__inner { max-width: 46rem; }
  .contact h1 { font-size: var(--fs-h1); margin: 0.4rem 0 1rem; }
  .contact .lead { color: var(--color-ink-soft); }
  .contact__methods {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0;
    display: grid;
    gap: 1rem;
  }
  .contact__methods li { margin: 0; }
  .contact__card {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1.2rem 1.4rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--color-ink);
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease),
      border-color 0.25s var(--ease);
  }
  .contact__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--color-purple) 35%, var(--color-border));
  }
  .contact__icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--color-bg-alt);
    color: var(--color-purple);
  }
  .contact__detail { display: flex; flex-direction: column; gap: 0.1rem; }
  .contact__label {
    font-size: var(--fs-small);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-purple);
  }
  .contact__value { font-weight: 600; word-break: break-word; }
  .contact__note { color: var(--color-ink-soft); font-size: var(--fs-small); }
  .contact__resume { margin-top: var(--space-6); color: var(--color-ink-soft); }
</style>
