---
import { getContent, type Lang } from '../i18n/content';

export interface Props {
  lang: Lang;
  altHref?: string;
}
const { lang, altHref = lang === 'es' ? '/' : '/es/' } = Astro.props;
const t = getContent(lang);
const home = lang === 'es' ? '/es/' : '/';

const links = [
  { href: `${home}#about`, label: t.nav.about, id: 'about' },
  { href: `${home}#projects`, label: t.nav.projects, id: 'projects' },
  { href: `${home}#experience`, label: t.nav.experience, id: 'experience' },
  { href: `${home}#contact`, label: t.nav.contact, id: 'contact' },
];

const langAriaLabel = lang === 'es' ? t.toggles.toEn : t.toggles.toEs;
---

<header class="site-header">
  <div class="container site-header__inner">
    <nav class="mainnav" aria-label="Primary">
      <ul>
        {links.map((link) => (
          <li>
            <a href={link.href} class="navpill" data-nav={link.id}>{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-tools">
      <button
        class="tool-btn"
        id="theme-toggle"
        type="button"
        aria-label={t.toggles.toDark}
        aria-pressed="false"
        data-label-dark={t.toggles.toDark}
        data-label-light={t.toggles.toLight}
      >
        <svg class="theme-icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <svg class="theme-icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7"/>
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </button>

      <a class="tool-btn tool-btn--lang" href={altHref} aria-label={langAriaLabel} hreflang={lang === 'es' ? 'en' : 'es'}>
        {t.toggles.langShort}
      </a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    // Theme toggle
    const tt = document.getElementById('theme-toggle');
    if (tt) {
      const sync = (theme) => {
        tt.setAttribute('aria-pressed', String(theme === 'dark'));
        tt.setAttribute('aria-label', theme === 'dark' ? tt.dataset.labelLight : tt.dataset.labelDark);
      };
      sync(document.documentElement.dataset.theme || 'light');
      tt.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem('theme', next); } catch (e) {}
        sync(next);
      });
    }

    // Active-section highlight
    const navLinks = document.querySelectorAll('.navpill[data-nav]');
    const byId = {};
    navLinks.forEach((l) => (byId[l.getAttribute('data-nav')] = l));
    const sections = ['about', 'projects', 'experience', 'contact']
      .map((id) => document.getElementById(id))
      .filter(Boolean);
    if ('IntersectionObserver' in window && sections.length) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const link = byId[entry.target.id];
            if (link && entry.isIntersecting) {
              navLinks.forEach((l) => { l.classList.remove('is-active'); l.removeAttribute('aria-current'); });
              link.classList.add('is-active');
              link.setAttribute('aria-current', 'true');
            }
          });
        },
        { rootMargin: '-45% 0px -50% 0px' }
      );
      sections.forEach((s) => io.observe(s));
    }
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
    backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--color-border);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    flex-wrap: wrap;
    padding-block: 0.6rem;
    min-height: 4.25rem;
  }

  /* Section nav as pill buttons */
  .mainnav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }
  .navpill {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-ink);
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1.5px solid transparent;
    background: transparent;
    transition: background-color 0.2s var(--ease), color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .navpill:hover {
    color: var(--color-purple);
    background: color-mix(in srgb, var(--color-purple) 10%, transparent);
  }
  .navpill.is-active {
    color: var(--color-purple);
    background: color-mix(in srgb, var(--color-purple) 14%, transparent);
  }

  .header-tools { display: flex; align-items: center; gap: 0.4rem; }
  .tool-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.6rem;
    border-radius: 999px;
    border: 1.5px solid var(--color-border);
    background: transparent;
    color: var(--color-ink);
    cursor: pointer;
    font: inherit;
    font-weight: 650;
    font-size: 0.85rem;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .tool-btn:hover { border-color: var(--color-purple); color: var(--color-purple); }
  .tool-btn--lang { letter-spacing: 0.04em; }

  /* Mobile: keep the header to a single row. The pill nav becomes a
     horizontally scrollable strip; the theme/language tools stay pinned. */
  @media (max-width: 47.99rem) {
    .site-header__inner { flex-wrap: nowrap; gap: 0.5rem; }
    .mainnav { min-width: 0; flex: 1 1 auto; }
    .mainnav ul {
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      -webkit-overflow-scrolling: touch;
      /* Fade hint that there's more to scroll */
      -webkit-mask-image: linear-gradient(90deg, #000 92%, transparent);
      mask-image: linear-gradient(90deg, #000 92%, transparent);
    }
    .mainnav ul::-webkit-scrollbar { display: none; }
    .navpill { flex: 0 0 auto; font-size: 0.9rem; padding: 0.5rem 0.75rem; }
    .header-tools { flex-shrink: 0; }
  }
</style>
